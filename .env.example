# iiko Server API
IIKO_SERVER_URL=https://your-iiko-server.example.com
IIKO_LOGIN=admin
IIKO_PASSWORD=secret

# OpenRouter (LLM)
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=anthropic/claude-sonnet-4

# OpenWeatherMap
OWM_API_KEY=your-owm-api-key
RESTAURANT_LAT=55.7558
RESTAURANT_LON=37.6173

# Forecasting parameters
PROCUREMENT_BUFFER_PCT=0.10
FORECAST_HORIZON_DAYS=30
HISTORY_MONTHS=24

# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/gurman
