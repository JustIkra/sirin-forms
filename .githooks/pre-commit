#!/usr/bin/env bash
# Pre-commit QA drift hook.
# Проверяет, что изменения в UI/API/backend сопровождаются обновлением тестов.
# Не запускает сами тесты — только анализирует staged-файлы.
#
# Установить один раз:
#   git config core.hooksPath .githooks

set -e

ROOT_DIR="$(git rev-parse --show-toplevel)"

PY_BIN="${PY_BIN:-$ROOT_DIR/.venv/bin/python}"
if [[ ! -x "$PY_BIN" ]]; then
    PY_BIN="$(command -v python3 || true)"
fi
if [[ -z "$PY_BIN" ]]; then
    echo "pre-commit: python не найден (поставь .venv или python3 в PATH)"
    exit 0
fi

exec "$PY_BIN" "$ROOT_DIR/scripts/check_qa_coverage.py"
